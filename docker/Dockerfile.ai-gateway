FROM python:3.13-slim

WORKDIR /app

COPY packages/ai-core /app/packages/ai-core
COPY packages/models /app/packages/models
COPY packages/database /app/packages/database
COPY services/ai-gateway /app/services/ai-gateway

RUN pip install --no-cache-dir \
    -e /app/packages/ai-core \
    -e /app/packages/models[postgres] \
    -e /app/packages/database \
    fastapi uvicorn[standard] httpx openai python-multipart sqlalchemy psycopg2-binary Pillow

ENV PYTHONPATH=/app/services/ai-gateway/src:/app/packages/ai-core/src:/app/packages/models/src:/app/packages/database/src

EXPOSE 8020

CMD uvicorn contentos_ai_gateway.main:app --host 0.0.0.0 --port 8020
