{
  "uid": "contentos-production",
  "title": "ContentOS — Production",
  "description": "Celery queues, pipelines and jobs (Tier E3)",
  "tags": ["contentos", "production", "celery"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Celery workers",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_celery_workers", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending tasks (total)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_celery_pending_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Running pipelines",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_pipelines_total{status=\"running\"}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Running jobs",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_jobs_total{status=\"running\"}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Celery queue depth by agent",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_celery_queue_depth", "legendFormat": "{{queue}}", "refId": "A" }],
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "min": 0 } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue depth over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "contentos_celery_pending_total", "legendFormat": "total pending", "refId": "A" },
        { "expr": "contentos_celery_workers", "legendFormat": "workers", "refId": "B" }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Pipelines by status",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_pipelines_total", "legendFormat": "{{status}}", "refId": "A" }],
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Jobs by status",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "contentos_jobs_total", "legendFormat": "{{status}}", "refId": "A" }],
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    }
  ]
}
