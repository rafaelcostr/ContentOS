# Application
APP_NAME=ContentOS
APP_ENV=development
DEBUG=true

# JWT
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Database
POSTGRES_USER=contentos
POSTGRES_PASSWORD=contentos_secret
POSTGRES_DB=contentos
DATABASE_URL=postgresql+asyncpg://contentos:contentos_secret@postgres:5432/contentos

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# MinIO
MINIO_ENDPOINT=minio:9000
# Browser-facing host for presigned preview URLs (Tier A3)
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=contentos
MINIO_SECRET_KEY=contentos_secret
MINIO_BUCKET=contentos
MINIO_SECURE=false

# AI Gateway (V2.1) — central routing for all AI calls
USE_AI_GATEWAY=true
AI_GATEWAY_URL=http://ai-gateway:8020
AI_GATEWAY_FALLBACK=true

# Prompt Manager (V2.2)
PROMPTS_DIR=
PROMPTS_OVERRIDE_DIR=/data/prompts

# Model Manager (V2.3) — per-agent configs in PostgreSQL (agent_model_configs)
# Fallback env vars when DB unavailable:
# OLLAMA_MODEL, PIPER_VOICE, WHISPER_MODEL

# Memory Manager (V2.4) — per-project creative memory in PostgreSQL (project_memory)
# Injected as memory_context in agent prompts automatically

# Cache Manager (V2.5) — Redis cache for LLM responses
USE_AI_CACHE=true
CACHE_REDIS_URL=redis://redis:6379/2
CACHE_DEFAULT_TTL_SECONDS=86400

# Cost Manager (V2.6) — tokens, duration, estimated USD per AI call (local = $0)

# Event Bus (V2.7) — Redis Streams + pub/sub + PostgreSQL event store
EVENT_STREAM_KEY=contentos:stream:events
EVENT_STREAM_MAXLEN=10000
EVENT_REDIS_URL=redis://redis:6379/0

# Analytics AI + Thumbnail (V2.8) — async agents after pipeline completes
ENABLE_ANALYTICS_AI=true
ENABLE_THUMBNAIL=false
ANALYTICS_AUTO_APPLY_MEMORY=false

# Content Sources + Clip Pipeline (V2.10) — async after scene step
ENABLE_V2_CLIP_PIPELINE=false
CONTENT_SOURCES_ENABLED=local_library,own_library,pexels,pixabay
CONTENT_SOURCE_RSS_URL=
CONTENT_SOURCE_CUSTOM_JSON=[]

# V5.0 — Media Acquisition (licensed sources only)
PEXELS_API_KEY=
PIXABAY_API_KEY=
MEDIA_MAX_DOWNLOAD_MB=50
MEDIA_ALLOWED_LICENSES=royalty_free,creative_commons
MEDIA_COLLECT_TOP_N=3
MEDIA_SEARCH_PER_PAGE=8
ENABLE_MEDIA_ANALYZE=true
MEDIA_ANALYZE_MAX_FRAMES=2
MEDIA_VISION_PROVIDER=ollama
MEDIA_EMBED_PROVIDER=ollama
# Production: require real clips (default on when APP_ENV=production)
MEDIA_REQUIRE_ASSETS=
MEDIA_REQUIRE_CLIPS=
# Production: block FFmpeg render with placeholder scenes (default false in prod)
RENDER_ALLOW_PLACEHOLDER=
ENABLE_TAKE_RECOMMENDATION=true
TAKE_SCORE_SEMANTIC_WEIGHT=40
TAKE_REUSE_PENALTY=25
ENABLE_ASSET_SEMANTIC_SEARCH=true
ASSET_SEMANTIC_MIN_SIMILARITY=0.12
ASSET_SEMANTIC_CANDIDATE_LIMIT=500

# Plugin Marketplace (V2.9)
PLUGINS_ROOT=/app/plugins

# Workflow templates (V2.12) — v1-default | v2-full | v2-dynamic | v5-media-autopilot
# Phase 8: use v2-dynamic for full Content Sources → Asset Manager pipeline
# V5.0.5: use v5-media-autopilot for lean media autonomy (GTA 6 E2E)
DEFAULT_WORKFLOW=v1-default

# V3 Video Reviewer (Tier B7) — score threshold for video_review_passed
VIDEO_REVIEW_MIN_SCORE=8
# V3 Quality Agent — technical score threshold (0–10)
QUALITY_MIN_SCORE=6
QUALITY_REQUIRE_REAL_MEDIA=
QUALITY_MIN_BITRATE_BPS=1000000
QUALITY_TARGET_LUFS=-16
QUALITY_LUFS_TOLERANCE=3

# TikTok live publish — poll status after upload
TIKTOK_PUBLISH_POLL_INTERVAL_SEC=3
TIKTOK_PUBLISH_POLL_TIMEOUT_SEC=120
# Max rewinds when video_score < VIDEO_REVIEW_MIN_SCORE (0 = never retry)
MAX_CREATIVE_RETRIES=1
# Step to restart from on creative retry (script|hook|script_review|takes)
CREATIVE_RETRY_FROM=script

# V5.2.2 Retention → auto_retry (hook, take, CTA)
RETENTION_RETRY_ENABLED=true
RETENTION_MIN_SCORE=65
RETENTION_MIN_HOOK_PCT=70
RETENTION_MIN_COMPLETION_PCT=40

# V5.2.3 SEO Engine (titles, hashtags, descriptions)
SEO_ENGINE_ENABLED=true
SEO_USE_LLM=true

# V5.2.4 AI Director (partial re-run by score)
AI_DIRECTOR_ENABLED=true
AI_DIRECTOR_MIN_SCORE=65
AI_DIRECTOR_DIMENSION_MIN=55
MAX_DIRECTOR_RETRIES=1

# V5.2.5 Creative Memory (merge KB + Learning)
CREATIVE_MEMORY_ENABLED=true
CREATIVE_MEMORY_KB_SEARCH_LIMIT=5

# V5.3 Content Factory
CONTENT_FACTORY_ENABLED=true
FACTORY_REQUIRE_APPROVAL=false
FACTORY_MAX_BATCH_SIZE=12

# V5.4.1 OAuth Platform Analytics
PLATFORM_ANALYTICS_ENABLED=true
PLATFORM_ANALYTICS_MEDIA_LIMIT=10

# V5.4.2 Performance Learning
PERFORMANCE_LEARNING_ENABLED=true
PERFORMANCE_LEARNING_AUTO_INDEX_KB=true
PERFORMANCE_LEARNING_AUTO_MEMORY=true
PERFORMANCE_LEARNING_AUTO_PROCESS=false
PERFORMANCE_LEARNING_MIN_CTR=0.04
PERFORMANCE_LEARNING_MIN_VIEWS=50

# V5.4.3 Comment Analyzer
COMMENT_ANALYZER_ENABLED=true
COMMENT_ANALYZER_MAX_COMMENTS=50
COMMENT_ANALYZER_AUTO_INDEX_KB=false

# V5.4.4 Community Agent (drafts only — no auto-post)
COMMUNITY_AGENT_ENABLED=true
COMMUNITY_AUTO_POST=false
COMMUNITY_DRAFTS_MAX=20

# AI Providers — stack local (zero cost)
TEXT_PROVIDER=ollama
SPEECH_PROVIDER=piper
SUBTITLE_PROVIDER=local

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
# Alternativa: qwen3:8b (requer ollama pull qwen3:8b)
OLLAMA_VISION_MODEL=llava
OLLAMA_EMBED_MODEL=nomic-embed-text
IMAGE_PROVIDER=local
VISION_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

PIPER_URL=http://piper:5000
PIPER_VOICE=pt_BR-faber-medium
DEFAULT_VOICE_PROFILE=default
ENABLE_VOICE_PROFILES=true

WHISPER_URL=http://whisper:8080
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Dev rápido: WHISPER_MODEL=small

# Alternativas cloud (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# FFmpeg / Editor (Fase 3)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
EDITOR_ENABLE_ZOOM=true
EDITOR_MUSIC_VOLUME=0.12
EDITOR_MUSIC_KEY=assets/music/ambient.mp3
EDITOR_FADE_DURATION=0.4
ENABLE_CINEMATIC_EDITOR=true
CINEMATIC_PRESET=default

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000

# Public API keys (Tier C5)
API_KEY_DEFAULT_RATE_LIMIT=120
# API_KEY_REDIS_URL=redis://localhost:6379/0

# Billing / Stripe (Tier C3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:3000/settings?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/settings?billing=cancel
BILLING_PIPELINE_CREDIT_COST=1
BILLING_ENFORCE_CREDITS=true
QUOTAS_ENFORCE=true
# Local docker compose defaults QUOTAS_ENFORCE=false unless set here.

# Scheduler (Tier D1)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60

# Unified Marketplace (Tier D3)
# MARKETPLACE_REMOTE_URL=https://example.com/contentos/catalog.json
MARKETPLACE_REMOTE_CACHE_SECONDS=300

# Prometheus (Tier E2)
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_TOKEN=
CONTENTOS_VERSION=0.1.0
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# SLO thresholds (V5.5.3)
SLO_POSTGRES_LATENCY_WARNING_MS=300
SLO_POSTGRES_LATENCY_CRITICAL_MS=500
SLO_QUEUE_BACKLOG_WARNING=50
SLO_QUEUE_BACKLOG_CRITICAL=150
SLO_PIPELINE_SUCCESS_MIN_PERCENT=95
SLO_JOB_SUCCESS_MIN_PERCENT=90
SLO_MIN_CELERY_WORKERS=1

# Gateway hardening (V5.5.4)
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_PER_MINUTE=300
GATEWAY_REQUEST_TIMEOUT_SECONDS=120
GATEWAY_RATE_LIMIT_EXEMPT_PATHS=/health,/health/ready,/metrics,/docs,/redoc,/openapi.json
LOADTEST_CONCURRENCY=20
LOADTEST_DURATION_SECONDS=30

# OpenTelemetry (Tier E1)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_FASTAPI_EXCLUDED_URLS=/health,/metrics

# Publishing (Fase 5 + Tier D4)
PUBLISH_MODE=dry_run
# dry_run | prepare_only | live — live blocked when QA fails if PUBLISH_REQUIRE_QA=true (default in prod)
PUBLISH_REQUIRE_QA=
ENABLED_PLATFORMS=tiktok,youtube,instagram
PLATFORM_CREDENTIALS_JSON={}
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/callback
DASHBOARD_URL=http://localhost:3000

# YouTube / Google OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Public Data API key — competitor sync (Fase 7)
YOUTUBE_API_KEY=

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Instagram / Meta OAuth
META_APP_ID=
META_APP_SECRET=

# Growth OS — rate limits (Fase 18)
GROWTH_RATE_LIMIT_ENABLED=true
GROWTH_RATE_LIMIT_PER_MINUTE=30
